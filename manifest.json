{
  "manifest_version": 3,
  "name": "Dumb Down — Google Messages login helper",
  "version": "1.5.8",
  "description": "Sends your Google Messages login to your Dumb Down flip phone via QR code. Nothing leaves your computer except to your phone.",
  "browser_specific_settings": {
    "gecko": {
      "id": "gmessages-login@dumb.co",
      "strict_min_version": "142.0",
      "update_url": "https://dumb.co/updates.json",
      "data_collection_permissions": {
        "required": ["authenticationInfo"]
      }
    }
  },
  "permissions": ["cookies", "storage"],
  "host_permissions": ["*://*.google.com/*"],
  "incognito": "spanning",
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dumb Down login helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
